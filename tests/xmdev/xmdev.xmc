[base]                          # base config, overriden by the default or the selected config
Arch = x64
Type = exe
EntryFile = xmdev               # names the .xm file that contains the entry function (defaults to the project name)
EntryFunc = main                # names entry point function (defaults to "main", as is set here)
Subsystem = console
LibPaths = [
    C:/Program Files/Microsoft Visual Studio/2022/Community/VC/Tools/MSVC/14.44.35207/lib/x64, 
    C:/Program Files (x86)/Windows Kits/10/Lib/10.0.19041.0/ucrt/x64,
	C:/Program Files (x86)/Windows Kits/10/Lib/10.0.19041.0/um/x64
]
StaticLibs = []
DynamicLibs = [kernel32.lib, shell32.lib]
SourceRoot = .                  # optional, the default is the current working directory, as is set here

[debug:default]                 # a config doesn't have to be debug or release, it can have any name
CRT = dynamic-debug             # static, dynamic, static-debug, dynamic-debug (plan to switch to static later, but for dev speed, doing this)
DebugSymbols = yes
IntPath = .
Output = .

[release]
CRT = dynamic                   # static, dynamic, static-debug, dynamic-debug
DebugSymbols = no
IntPath = .
Output = . 