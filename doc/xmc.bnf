; xmc Language Grammar (Tentative BNF, Revision 1.7)
;===================================================
; Notation:
;   ::=      definition
;   |        alternate
;   { }      zero or more repetitions
;   [ ]      zero or one (optional)
;   ( )      grouping
;   "x"      literal terminal
;   < >      whitespace is not allowed between groups of items surrounded by angle brackets
;            (whitespace is allowed before and after such groups)
;   UPPER    lexer token (defined in the Tokens section at the bottom)
;
; Dot vs Colon (Key Decision #11): The dot "." always operates on a value;
; the colon ":" always operates on a scope or names a relationship between
; scopes. The parser disambiguates by symbol-table context.
;
; The colon is used as:
;   - The first character of ":=" (reference assignment, a single two-character token)
;   - Vault qualifier in a variable declaration: var x:arenaname
;   - Inheritance qualifier when declaring structs and classes: class Dog : Animal
;   - An extern qualifier in an extern declaration: kernel32:WriteFile(..)
;   - A delimiter between segments of a namespace path: filename:foo
;   - A class-scope qualifier for static and once members: ClassName:Member
;   - An enum-scope qualifier for named values: EnumName:ValueName
;   - A label/case terminator: { :loop ... } and case-label expressions
;
; The dot is used as:
;   - Member access on a value: instance.member, struct.field
;   - Pointer member access (auto-dereferenced for raw and arc pointers)
;
; "*" and "&" are context-sensitive:
;   In a type position  -> ptr-type constructors (*T, &T)
;   In an expression    -> multiplication and bitwise-and
;
;============================================================================
; TOP LEVEL
;============================================================================

program
    ::= { top-level-declaration }

top-level-declaration
    ::= arena-declaration
    | class-declaration
    | enum-declaration
    | error-declaration
    | extern-declaration
    | function-declaration
    | namespace-declaration
    | struct-declaration
    | use-directive
    | variable-declaration

;============================================================================
; ARENA DECLARATIONS
;----------------------------------------------------------------------------
;
; An optional u64 size parameter is passed to an arena constructor.

arena-declaration
    ::= "arena" IDENTIFIER [ "(" expression ")" ] ";"
    | [ "arena" | "var" ] IDENTIFIER "=" "arena" [ "(" expression ")" ] ";"

;============================================================================
; CLASS DECLARATIONS
;----------------------------------------------------------------------------

class-declaration
    ::= "class" IDENTIFIER [ ":" base-class-list ] "{" { class-member } "}" [ IDENTIFIER ] ";"

; The optional trailing IDENTIFIER, when present, declares an instance of
; the class in the surrounding scope, parallel to the struct form.

base-class-list
    ::= qualified-name { "," qualified-name }

class-member
    ::= data-member
    | constructor-declaration
    | destructor-declaration
    | function-member

data-member
    ::= [ "once" ] type-specifier <IDENTIFIER> { array-suffix } [ UGLY-MASK ] [ "=" expression ] ";"

constructor-declaration
    ::= IDENTIFIER "(" [ parameter-list ] ")" function-body

destructor-declaration
    ::= "~" IDENTIFIER function-body

; function-body is defined under FUNCTIONS below.

function-member
    ::= [ "static" ] [ type-specifier ] IDENTIFIER "(" [ parameter-list ] ")" function-body

; "once" data members declare class-level storage shared across all instances,
; lazily initialized on first reach (section 26g). "static" function members
; belong to the class scope, take no implicit receiver, and are called with
; the colon qualifier: ClassName:Member() (section 26h).

;----------------------------------------------------------------------------
; TYPE SPECIFIERS
;----------------------------------------------------------------------------
;
; "arc" before a type denotes a shared pointer:
;
;   arc Node   next;       -- shared pointer to a Node
;   arc var    handler;    -- shared pointer to a morphing variant
;   arc zs8    name;       -- shared pointer to a zs8
;
; "ref" declares a variable whose type is inferred from its first assignment
; and then held fixed — no morphing occurs after that point. This is the
; correct declaration form for function references and for any variable
; where you want inference without the risk of subsequent type changes:
;
;   ref fn1 = myInstance.AddToList(zs8);    -- bound, signature (zs8) -> null
;   ref fn2 = MyClass:Swap(i32, i32);       -- unbound, signature (i32, i32) -> null
;   ref x   = 5;                            -- x is u8, frozen
;
; "var" declares a variable that infers its type and is free to morph.
; "ref" declares a variable that infers its type and is immediately frozen.
;
; function-type provides an explicit function signature:
;
;   function(zs8) -> b  fn3;
;   *function(zs8) -> b fn9;     -- raw pointer to a function
;   &function(zs8) -> b fn10;    -- arc pointer to a function

type-specifier
    ::= { low-refinement-qualifier } base-type
    | { low-refinement-qualifier } qualified-name
    | ptr-type
    | "var"                       ; inferred, morphable
    | "ref"                       ; inferred, frozen after first assignment
    | "arc" type-specifier        ; arc/shared pointer to type
    | function-type               ; explicit function signature

; Type specifiers for function parameters use high-refinement specifiers
; (like "concurrent") to specify minimum refinements required.
; A "ref" parameter infers its type from each call site and produces a
; specialized version of the enclosing function per distinct inferred type,
; following the same implicit-generics rules as unresolved "var" parameters —
; the difference is that within each specialization the type is frozen.

parameter-type-specifier
    ::= { high-refinement-qualifier } base-type
    | { high-refinement-qualifier } qualified-name
    | ptr-type
    | "var"
    | "ref"
    | "arc" type-specifier        ; shared pointer parameter
    | function-type
    ;
    ; Parameters declared with ptr-type (**Node, *&Node, etc.) are explicit
    ; pointer parameters. They do not participate in refinement morphing.
    ; The compiler does not infer or adjust their pointer depth.
    ; raw and arc qualifiers on non-ptr-type parameters continue to set
    ; maxrmask and minrmask bits as before (although, to be clear, both raw
    ; and arc imply virtual. There are no raw or arc materialized values.)

base-type
    ::= "b"
    | "i8" | "i16" | "i32" | "i64"
    | "u8" | "u16" | "u32" | "u64"
    | "f32" | "f64"
    | "d16" | "d32" | "d64"
    | "c8" | "c16"
    | "zs8" | "zs16" | "zs32"
    | "s8" | "s16"
    | "utf8" | "us"
    | "Class"                     ; built-in type produced by typeof(); section 12f
    | container-type
    | generic-type                ; parameterized: array<T>, list<T>, Generator<T>, ...
    | "arena"
    | "heap"

; Note: bare "function" has been superseded by the function-type production
; (see FUNCTION TYPES AND REFERENCES below). Use ref, var, or function(...)
; to declare function variables.

container-type
    ::= "btree"
    | "list"
    | "array"
    | "hashmap"
    | "hashset"
    | "mpmc_queue"
    | "mpsc_queue"
    | "spsc_queue"
    | "spmc_queue"
    | "stack"
    | "queue"

; Generic types are parameterized by one or more type-specifiers in angle
; brackets. The grammar accepts angle-bracket parameterization on any of the
; container keywords above and on user-defined names; the morpher validates
; whether the named type actually supports parameterization.
;
; Examples:
;   array<i32>           array<var>          array<ref>
;   list<i64>            list<Generator<u8>>
;   Generator<list>      Generator<MyType>
;   array<array<i32>>    hashmap<zs8, i32>

generic-type
    ::= ( container-type | "Generator" | qualified-name ) "<" type-list ">"

; The open-array suffix "[]" appears only in FFI / pointer-target positions
; to express "array of T, size determined elsewhere" — see ptr-type below
; and section 9j. It is not a standalone type.

;----------------------------------------------------------------------------
; REFINEMENT QUALIFIERS
;----------------------------------------------------------------------------
;
; Minimum refinement qualifiers constrain what the compiler must assume
; about a variable or parameter — the floor below which morphing cannot go.
; Maximum refinement qualifiers (ugly mask) cap the ceiling.
;
; Bit layout, position 7 down to 0:
;   7: immutable(i) | mutable(m)
;   6: fixed(f)     | resizable(r)
;   5: materialized(m) | virtual(v)
;   4: raw(r)       | arc(a)
;   3: homogenous(h)| heterogenous(e)
;   2: rigid(r)     | fluid(f)
;   1: serial(s)    | concurrent(c)
;   0: singular(s)  | variant(v)
;
; Shared letters are disambiguated purely by their position in the mask string.

low-refinement-qualifier
    ::= "immutable"
    | "fixed"
    | "materialized"
    | "raw"
    | "homogenous"
    | "rigid"
    | "serial"
    | "singular"

high-refinement-qualifier    ; at least one space is required after the qualifier
    ::= "mutable "
    | "resizable "
    | "virtual "
    | "arc "
    | "heterogenous "
    | "fluid "
    | "concurrent "
    | "variant "

; Pointer constructors — no whitespace allowed between * or & and the type.
; The optional "[]" suffix marks a pointer to an open-size array, used in FFI
; to express the equivalent of C's "T*" parameter type (see section 9j).

ptr-type
    ::= <"*"> <type-specifier> [ <"["> <"]"> ]    ; raw pointer, optionally to open array
    | <"&"> <type-specifier> [ <"["> <"]"> ]      ; arc pointer, optionally to open array

;============================================================================
; FUNCTION TYPES AND REFERENCES
;----------------------------------------------------------------------------
;
; function-type states a complete function signature. It can appear anywhere
; a type-specifier is valid: variable declarations, parameter types, ptr-type
; operands (*function(...) -> T, &function(...) -> T), and is-checks:
;
;   function(zs8) -> b  fn3;
;   *function(zs8) -> b fn9;
;   fn is function(i32, i32)          -- is-check, return type omitted
;   fn is function(i32, i32) -> b     -- is-check, return type specified
;
; In an is-check the return type is optional (see postfix-op and section 18i).
; In a declaration it is always optional (null is the implicit return type).

function-type
    ::= "function" "(" [ type-list ] ")" [ "->" type-specifier ]

type-list
    ::= type-specifier { "," type-specifier }

; function-ref-expr specializes a generic function or selects a specific
; overload, producing a callable reference. The parenthesised list contains
; type-specifiers, not value expressions — it is a specialization directive,
; not a function call. Syntactically it resembles a function call; the parser
; disambiguates by expected context (the target type is ref or function-type)
; and by whether the arguments resolve as types or values.
;
; A reference taken from a class name is unbound (receiver passed at call time
; as the first argument). A reference taken from an instance is bound (receiver
; captured at storage time, not passed at the call site).
;
; An unspecialized generic (var parameters) cannot be stored in a ref or
; function-type variable — a full type-list specialization must be supplied.
; Assigning a bare unspecialized name is a compile-time error:
;
;   ref fn6 = MyClass:Swap(i32, i32);    -- ok: specialization provided
;   ref fn7 = MyClass:Swap(f32, f32);    -- ok: different specialization
;   ref fn8 = MyClass:Swap;              -- error: unspecialized generic

function-ref-expr
    ::= qualified-name "(" [ type-list ] ")"

;============================================================================
; ERROR DECLARATIONS
;----------------------------------------------------------------------------
;
; Declares a class with an inferred constructor and a functor, inheriting from
; the built-in XmcError base. Parameter values are automatically forwarded to
; automatically declared members of the same name and type.

error-declaration
    ::= "error" IDENTIFIER "(" [ parameter-list ] ")" ";"

;============================================================================
; EXTERN DECLARATIONS
;----------------------------------------------------------------------------

extern-declaration
    ::= "extern" qualified-name "(" [ extern-parameter-list ] ")"
    [ "->" type-specifier [ ":" IDENTIFIER ] ] ";"

extern-parameter-list
    ::= extern-parameter { "," extern-parameter }

extern-parameter
    ::= IDENTIFIER "->" type-specifier [ ":" IDENTIFIER ]

; The "-> type : register" form spells the type and its register binding the
; same way for parameters and for the return. Parameters lead with the name;
; the return has no name. The register binding is optional in both positions:
; an extern parameter without ": register" is passed on the stack, and an
; extern with no return-register clause names a void-returning extern.

;============================================================================
; FUNCTIONS
;----------------------------------------------------------------------------
;
; A function with no return type specifier is a procedure (returns nothing).
; A function containing a "yield" statement is a generator; the return type
; names the yielded element type. The compiler-internal generator wrapper
; type is __Generator and is not referenced by name in programmer code.
; A function with parameters or locals whose types are not resolved within
; its scope are inlined at each call site where types are resolved from the
; context. If they remain unresolved by the end of compilation, a compile-time
; error is emitted.

function-declaration
    ::= [ type-specifier ] IDENTIFIER "(" [ parameter-list ] ")" function-body

parameter-list
    ::= [ parameter { "," parameter } ] [ parameter-with-default { "," parameter-with-default } ] [ "," variadic-parameter ]
    | variadic-parameter

; A parameter with no type specifier is implicitly var.
; When "ref" is used as a parameter type, the compiler infers the type from
; the argument supplied at each call site and produces a specialized version
; of the enclosing function per distinct inferred type. Within each
; specialization the type is frozen (same implicit-generics rules as
; unresolved "var" parameters, but without subsequent morphing).

parameter
    ::= [ parameter-type-specifier ] <IDENTIFIER> { array-suffix } [ <UGLY-MASK> ]

parameter-with-default
    ::= [ parameter-type-specifier ] <IDENTIFIER> { array-suffix } [ <UGLY-MASK> ] "=" expression

variadic-parameter
    ::= <IDENTIFIER> <"...">

function-body
    ::= "{" { statement } "}"

anonymous-function
    ::= "(" [ parameter-list ] ")" "{" { statement } "}"

; Capture is inferred from usage. Value vs reference capture depends on the
; refined type of each captured variable.

nested-function-declaration
    ::= function-declaration

; Functions may be nested inside other functions.
; Reaching into a nested function from its enclosing scope is not permitted.

;============================================================================
; STATEMENTS
;----------------------------------------------------------------------------

statement
    ::= arena-declaration
    | variable-declaration
    | nested-function-declaration
    | use-directive
    | if-statement
    | for-statement
    | while-statement
    | do-statement
    | switch-statement
    | spawn-statement
    | labeled-block
    | error-block
    | block
    | return-statement
    | yield-statement
    | break-statement
    | continue-statement
    | assignment-statement
    | expression-statement

block
    ::= "{" { statement } "}"

;----------------------------------------------------------------------------
; CONTROL FLOW
;----------------------------------------------------------------------------

if-statement
    ::= "if" "(" expression ")" statement
    { "else" "if" "(" expression ")" statement }
    [ "else" statement ]

for-statement
    ::= "for" "(" for-init ";" [ expression ] ";" [ expression ] ")" statement
    | "for" "(" [ "var" | type-specifier ] for-bind-target "in" expression ")" statement

for-init
    ::= variable-declaration
    | expression-statement
    | type-specifier IDENTIFIER "=" expression

; for-bind-target supports tuple unpacking when the source produces tuples
; (such as the standard-library zip() generator). For ordinary single-value
; iteration, just one identifier appears.

for-bind-target
    ::= IDENTIFIER { "," IDENTIFIER }

while-statement
    ::= "while" "(" while-cond ")" statement

; while-cond is either a plain boolean expression, or a binding form that
; declares a loop-local name and uses the bound value's truthiness as the
; loop condition. In the binding form, an exhaustion signal from a generator-
; handle method (e.g. gen.next()) becomes the loop-exit edge instead of
; binding to the name. See section 11d.

while-cond
    ::= expression
    | ( "var" | type-specifier ) IDENTIFIER "=" expression

do-statement
    ::= "do" statement "while" "(" expression ")" ";"

;----------------------------------------------------------------------------
; SWITCH AND CASE
;----------------------------------------------------------------------------
;
; The switch statement matches a value against an ordered set of cases and
; runs the body of the first matching case. There is no fall-through.
; See section 12.
;
; The switch key may be plain (the value is referenced via the implicit
; binding "it" in expression-form cases) or named (declared with var or a
; type-specifier in the parens, to introduce a name visible in every case
; body and expression-form label):
;
;   switch (n)                      ; plain
;   switch (var result = expr)      ; named binding
;
; Case labels are one of:
;   - Value-list: a comma-separated list of expressions whose value is known
;     at the comparison point. Matches if the key equals any value (==).
;   - Expression: a boolean expression that mentions "it" or the named
;     binding. Matches if the expression evaluates truthy.
;   - Default ("*"): matches any key the previous cases did not match. At
;     most one per switch.
;
; The compiler distinguishes the value-list and expression forms by whether
; the case-label expression(s) reference "it" or the named binding.

switch-statement
    ::= "switch" "(" switch-key ")" "{" { switch-case } [ default-case ] "}"

switch-key
    ::= expression
    | ( "var" | type-specifier ) IDENTIFIER "=" expression

switch-case
    ::= case-label ":" case-body

case-label
    ::= expression { "," expression }

default-case
    ::= "*" ":" case-body

case-body
    ::= statement

;----------------------------------------------------------------------------
; LABELED BLOCKS AND REACHING
;----------------------------------------------------------------------------
;
; A labeled block creates a named scope. The label acts as a local namespace
; within the enclosing function. It may shadow a global namespace of the same
; name within that function. Variables declared inside the block are reachable
; in the enclosing function scope after the block exits; if the block was
; skipped at runtime, those variables are null. Reaching does not cross
; function boundaries — you cannot reach into a nested function.

labeled-block
    ::= "{" ":" IDENTIFIER { statement } "}"

;----------------------------------------------------------------------------
; SPAWN / THREADING
;----------------------------------------------------------------------------

spawn-statement
    ::= [ ( "var" | "ref" | type-specifier ) IDENTIFIER "=" ] "spawn"
    ( function-call | anonymous-block ) ";"

anonymous-block
    ::= "{" { statement } "}"

;----------------------------------------------------------------------------
; ERROR HANDLING
;----------------------------------------------------------------------------
;
; Error block: if any expression inside produces a variant whose tag inherits
; from XmcError, execution immediately exits the block. Also exits if a void
; call sets __missing_attribute (runtime attribute lookup failure).

error-block
    ::= "{?" { statement } "?}"

; Error operator: used as an expression. If the left-hand side is an error
; variant, the handler block runs. See error-expression in the expression
; grammar.

;============================================================================
; ASSIGNMENT AND SIMPLE STATEMENTS
;============================================================================
;
; "$" on the left side of an assignment dereferences the pointer and writes
; through it:
;   $pp = x        -- writes x to the location pp points at
;   $pp->field = x -- dereferences pp, then writes to field
;   $pp += 1       -- compound assignment through a pointer

assignment-statement
    ::= lvalue "=" expression ";"
    | lvalue ":=" expression ";"
    | lvalue compound-assign-op expression ";"

compound-assign-op
    ::= "+=" | "-=" | "*=" | "/=" | "%=" | "&=" | "|=" | "^="

; lvalue covers simple names, member access, subscript, and pointer
; dereferences. The semantic checker verifies the result is mutable.

return-statement
    ::= "return" [ expression ] ";"

yield-statement
    ::= "yield" expression ";"

break-statement
    ::= "break" [ ":" IDENTIFIER ] ";"

continue-statement
    ::= "continue" [ ":" IDENTIFIER ] ";"

; A bare break inside a switch nested in a loop exits the switch, not the
; loop. To exit the loop from inside the switch, use a labeled break with
; the loop's label. continue is a loop construct; a continue inside a
; switch case applies to an enclosing loop.

expression-statement
    ::= expression ";"

;============================================================================
; NAMESPACES
;============================================================================
;
; Namespace blocks must begin with the "namespace" keyword.
; You cannot declare a symbol into a namespace other than the current one.
; "var ns1:varname = x;" is not legal as a declaration.
; "ns1:varname" in an expression context is a qualified reference.

namespace-declaration
    ::= "namespace" IDENTIFIER "{" { top-level-declaration } "}"

;============================================================================
; QUALIFIED NAMES (namespace paths and member access)
;============================================================================
;
; ":" serves multiple roles disambiguated by symbol table context at
; parse/resolve time: identifier segments that name namespaces are namespace
; path components; the first segment that names a non-namespace symbol
; switches to member access. The full path only needs to be specified when
; there is ambiguity; the shortest unambiguous prefix is sufficient.
; The namespace path has an optionally-specified first segment which is the
; filename the symbol is declared in.

qualified-name
    ::= IDENTIFIER { ":" IDENTIFIER }

;----------------------------------------------------------------------------
; EXPRESSIONS
;----------------------------------------------------------------------------
;
; Precedence follows C++ conventions, encoded via recursive nesting.
; The ternary operator (?:) is excluded — use the inline if/then/else form.

expression
    ::= error-expression

error-expression
    ::= conditional-expr [ "|" "{" { statement } "}" ]

; The "|" error operator binds loosely, below all other operators.

conditional-expr
    ::= "if" expression "then" expression "else" expression
    | logical-or-expr

logical-or-expr
    ::= logical-and-expr { "||" logical-and-expr }

logical-and-expr
    ::= bitwise-or-expr { "&&" bitwise-or-expr }

bitwise-or-expr
    ::= bitwise-xor-expr { "|" bitwise-xor-expr }

bitwise-xor-expr
    ::= bitwise-and-expr { "^" bitwise-and-expr }

bitwise-and-expr
    ::= equality-expr { "&" equality-expr }

equality-expr
    ::= relational-expr { ( "==" | "!=" ) relational-expr }

relational-expr
    ::= shift-expr { ( "<" | ">" | "<=" | ">=" ) shift-expr }

shift-expr
    ::= additive-expr { ( "<<" | ">>" ) additive-expr }

; Pointer arithmetic:
;   *T + u64  ->  *T    (offset pointer forward by n elements)
;   *T - u64  ->  *T    (offset pointer backward by n elements)
;   *T - *T   ->  u64   (distance between two pointers of the same type)
; All other arithmetic on pointer types is a compile-time error.
; The subscript operator [n] on a *T is equivalent to (*T + n) dereferenced,
; and is the preferred idiom for pointer-offset access.

additive-expr
    ::= multiplicative-expr { ( "+" | "-" ) multiplicative-expr }

multiplicative-expr
    ::= unary-expr { ( "*" | "/" | "%" ) unary-expr }

; Precedence note:
;   "$" binds tighter than "->",  so $pp->next  parses as ($pp)->next.
;   "@" binds looser  than "->",  so @pp->next  parses as @(pp->next).
;   "@haystack[i]"                parses as @(haystack[i]), yielding *T.

unary-expr
    ::= postfix-expr
    | "-" unary-expr
    | "!" unary-expr
    | "~" unary-expr
    | "++" unary-expr
    | "--" unary-expr
    | <"@"> <unary-expr>    ; address-of: yields ptr-type one level deeper
    | <"$"> <unary-expr>    ; dereference: yields the value pointed at
    | "new" function-call   ; explicit heap construction; section 26a

postfix-expr
    ::= primary-expr { postfix-op }

postfix-op
    ::= "." IDENTIFIER
    | <"->"> <IDENTIFIER>                     ; dereference and access member
    | "[" expression "]"                       ; subscript
    | "[" [ expression ] ":" [ expression ] "]" ; slice
    | "[" [ expression ] ":" [ expression ] ":" [ expression ] "]" ; slice with stride
    | "(" [ argument-list ] ")"               ; call
    | "++"
    | "--"
    | "is" type-specifier
    ;
    ; The "is" operator works with all type-specifier forms, including
    ; function-type. When checking a function reference, the return type
    ; is optional:
    ;
    ;   fn is function(i32, i32)         -- matches any fn taking (i32,i32)
    ;   fn is function(i32, i32) -> b    -- matches only if return type is b
    ;
    ; Parameter types must match exactly. If the return type is omitted, the
    ; call is made and the return value is assigned to the left-hand side; if
    ; the actual return type is incompatible with the lhs, the lhs receives
    ; null. See section 18i for full semantics.
    ;
    ; The slice form supports an optional stride: a[start:stop:stride].
    ; Negative strides reverse: a[::-1] reverses the sequence.

primary-expr
    ::= literal
    | IDENTIFIER
    | "me"
    | "null"
    | "__missing_attribute"
    | "(" expression ")"
    | anonymous-function
    | list-expr
    | brace-expr                ; anonymous struct, dict, or curly-list literal
    | list-comprehension
    | dict-comprehension
    | range-expression
    | typeof-expr
    | function-ref-expr

typeof-expr
    ::= "typeof" "(" expression ")"

; typeof returns the runtime class of its operand as a value of the built-in
; type Class. Class values can be compared with == and != (exact identity,
; not inheritance) and are first-class in switch keys. Section 12f.

; __missing_attribute is a thread-local built-in flag. It is set to true after
; every runtime attribute lookup that finds no attribute, and cleared after
; every lookup that succeeds. The compiler generates code to track it only
; when it is referenced in the source scope where the lookup occurs.
; It reflects the result of the most recent attribute lookup only.
;
; After a call expression of the form handler.onClick(x, y), __missing_attribute
; reflects the onClick lookup specifically, not any argument sub-expressions.
;
; Typical use patterns:
;
;   ; option 1 — function reference is truthy when non-null
;   if (handler.onClick)
;       handler.onClick(x, y);
;
;   ; option 2 — error block exits if __missing_attribute is set
;   {?
;       handler.onClick(x, y);
;       DoSomethingThatOnlyMakesSenseIfOnClickRan();
;   ?}
;
;   ; option 3 — check flag manually
;   handler.onClick(x, y);
;   if (__missing_attribute) { ... }

;============================================================================
; COMPOSITE LITERALS
;----------------------------------------------------------------------------
;
; Square-bracket literal -> list (always).
; Curly-brace literal    -> one of:
;     - empty dict (when "{}")
;     - anonymous struct (when all elements are ".field = value" form)
;     - dict (when all elements are "key : value" form)
;     - list (when no elements have keyed form; in inferred-type context)
;     - aggregate initializer (in typed context — array elements, struct
;       fields, etc.; the declared type tells the compiler what to do)
;
; Mixing the three element forms within a single brace literal is an error.
; See section 5e.

list-expr
    ::= "[" [ expression { "," expression } [ "," ] ] "]"

brace-expr
    ::= "{" "}"                                                    ; empty dict
    | "{" struct-field-init { "," struct-field-init } [ "," ] "}"  ; anonymous struct
    | "{" dict-entry { "," dict-entry } [ "," ] "}"                ; dict
    | "{" expression { "," expression } [ "," ] "}"                ; list / initializer

struct-field-init
    ::= "." IDENTIFIER "=" expression

dict-entry
    ::= expression ":" expression

;----------------------------------------------------------------------------
; FUNCTION CALLS AND ARGUMENTS
;----------------------------------------------------------------------------

function-call
    ::= qualified-name "(" [ argument-list ] ")"

argument-list
    ::= argument { "," argument }

; Arguments may be positional or named. Named arguments allow left-side
; omission. Positional arguments may follow named ones when position is
; still unambiguous given which parameters have been named.

argument
    ::= [ IDENTIFIER "=" ] expression
    | list-expr     ; positional struct initializer passed directly
    | brace-expr    ; named struct initializer passed directly

;----------------------------------------------------------------------------
; COMPREHENSIONS AND RANGES
;----------------------------------------------------------------------------
;
; Comprehensions follow Python syntax. A list comprehension produces a list;
; a dict comprehension produces a dict (and supports tuple-unpacking targets
; for sources like zip()). The morpher initializes the result with default
; rmasks and lets usage drive subsequent morphing.

list-comprehension
    ::= "[" expression "for" [ "var" | type-specifier ] for-bind-target
    "in" expression [ "if" expression ] "]"

dict-comprehension
    ::= "{" expression ":" expression "for" [ "var" | type-specifier ] for-bind-target
    "in" expression [ "if" expression ] "}"

range-expression
    ::= "range" "(" expression [ "," expression [ "," expression ] ] ")"

; range(stop), range(start, stop), or range(start, stop, step). It is a
; standard-library generator returning successive integers; the handle is
; just a generator handle (section 19c).

;----------------------------------------------------------------------------
; LITERALS
;----------------------------------------------------------------------------

literal
    ::= INTEGER-LITERAL
    | FLOAT-LITERAL
    | DECIMAL-LITERAL
    | STRING-LITERAL
    | CHAR-LITERAL
    | BOOL-LITERAL

BOOL-LITERAL ::= "true" | "false"

;----------------------------------------------------------------------------
; TOKENS (Lexer)
;----------------------------------------------------------------------------

KEYWORD
    ::= "var" | "ref" | "namespace"
    | "immutable" | "mutable" 
    | "fixed" | "resizable"
    | "materialized" | "virtual" 
    | "raw" | "arc"
    | "homogenous" | "heterogenous" 
    | "rigid" | "fluid" 
    | "serial" | "concurrent" 
    | "singular" | "variant"
    | "struct" | "class" | "enum" | "error" | "extern" | "weak"
    | "use"
    | "once" | "static" | "new"
    | "arena" | "heap" | "function"
    | "null" | "me" | "is" | "true" | "false"
    | "typeof" | "Class" | "Generator"
    | "__missing_attribute" | "__carry" | "__overflow"
    | "if" | "then" | "else" | "for" | "while" | "do" | "in"
    | "switch" | "case"
    | "return" | "yield" | "break" | "continue" | "spawn"
    | "b"
    | "i8" | "i16" | "i32" | "i64"
    | "u8" | "u16" | "u32" | "u64"
    | "f32" | "f64"
    | "d16" | "d32" | "d64"
    | "c8" | "c16"
    | "zs8" | "zs16" | "zs32"
    | "s8" | "s16"
    | "utf8" | "us"
    | "list" | "array" | "queue" | "stack" | "btree" | "hashset" | "hashmap"
    | "spsc_queue" | "spmc_queue" | "mpsc_queue" | "mpmc_queue"
    | "range"
    | "@"     ; address-of operator
    | "$"     ; dereference operator
    | "->"    ; pointer member access operator

; "*" and "&" are context-sensitive:
;   In a type position  -> ptr-type constructors (*T, &T)
;   In an expression    -> multiplication (*) and bitwise-and (&) as usual
; "@"  -> address-of  (unary prefix; no whitespace permitted before operand)
; "$"  -> dereference (unary prefix; no whitespace permitted before operand)
; "->" -> pointer member access (postfix; no whitespace before member name)

IDENTIFIER
    ::= LETTER { LETTER | DIGIT | "_" }

; Must not match a KEYWORD.
; ":=" is always lexed as a single two-character token.
; ":" alone is valid only as a vault qualifier in a declaration, as an
; inheritance indicator, or as a namespace path separator.
; "." is a single-character token; the parser determines from context whether
; it is a namespace separator or a member-access operator.

; Ugly mask: immediately follows a variable or parameter name with no
; intervening whitespace. Tilde followed by 1–8 positional letters, one per
; bit from position 7 down to 0.
;
;   Position:    7  6  5  4  3  2  1  0
;   Zero side:   i  f  m  r  h  r  s  s
;   One  side:   m  r  v  a  e  f  c  v
;
; Examples:
;   var myvar~ifmrhrss;    all positions explicitly zero (fully minimal)
;   var myvar~mrva;        bits 7–4 = mutable/resizable/virtual/arc;
;                          bits 3–0 default to zero

UGLY-MASK
    ::= "~" MASK-CHAR { MASK-CHAR }

; 1 to 8 characters, no whitespace.

MASK-CHAR
    ::= "i" | "m" | "f" | "r" | "v" | "a" | "h" | "e" | "s" | "c"

INTEGER-LITERAL
    ::= DIGIT { DIGIT }
    | "0x" HEX-DIGIT { HEX-DIGIT }
    | "0b" BIN-DIGIT { BIN-DIGIT }

FLOAT-LITERAL
    ::= DIGIT { DIGIT } "." { DIGIT }
    [ ( "e" | "E" ) [ "+" | "-" ] DIGIT { DIGIT } ]

; Decimal literals use a "d" suffix. No floating point representation is used.

DECIMAL-LITERAL
    ::= DIGIT { DIGIT } "." DIGIT { DIGIT } "d"

; String literals support interpolation: {identifier} or {identifier.member}

STRING-LITERAL
    ::= '"' { STRING-CHAR | STRING-INTERPOLATION } '"'

STRING-INTERPOLATION
    ::= "{" IDENTIFIER [ "." IDENTIFIER ] "}"

; Deeper paths and arbitrary expressions inside interpolation are not yet specified.

CHAR-LITERAL
    ::= "'" CHAR-CHAR "'"

LETTER    ::= "a".."z" | "A".."Z" | "_"
DIGIT     ::= "0".."9"
HEX-DIGIT ::= DIGIT | "a".."f" | "A".."F"
BIN-DIGIT ::= "0" | "1"

STRING-CHAR  ::= any character except '"' and '{', or an escape sequence
CHAR-CHAR    ::= any character except "'", or an escape sequence

LINE-COMMENT  ::= "//" { any character except newline }
BLOCK-COMMENT ::= "/*" { any character } "*/"

;============================================================================
; STRUCT DECLARATIONS
;----------------------------------------------------------------------------
;
; Structs have no function members but may have named function-pointer members
; (via the function-type or ref type-specifier forms).
; A compiler-generated default constructor accepts parameters matching the
; member list in declaration order.

struct-declaration
    ::= "struct" [ IDENTIFIER ] [ ":" base-class-list ] "{" { struct-member } "}" [ IDENTIFIER ] ";"

; The trailing IDENTIFIER, when present, declares an instance of the struct
; in the surrounding scope. The optional ":" base-class-list is the struct
; inheritance form (section 23d / section 25); it parallels class inheritance.

struct-member
    ::= type-specifier <IDENTIFIER> { array-suffix } [ UGLY-MASK ] [ "=" expression ] ";"

;============================================================================
; ENUM DECLARATIONS
;----------------------------------------------------------------------------
;
; An enum declares a named scope containing a set of named integer values.
; Per the dot-vs-colon rule, values are reached via "EnumName:ValueName".
; The underlying integer type defaults to the smallest unsigned int that fits
; all of the declared values; an explicit override uses the angle-bracket
; form, e.g. enum<i32> ErrCode { OK, NotFound, Denied };
;
; Each value name may optionally be assigned a constant integer expression;
; unspecified values take the previous value plus one, with the first
; defaulting to zero.

enum-declaration
    ::= "enum" [ "<" integer-type ">" ] IDENTIFIER "{" enum-value-list "}" ";"

enum-value-list
    ::= enum-value { "," enum-value } [ "," ]

enum-value
    ::= IDENTIFIER [ "=" expression ]

integer-type
    ::= "i8" | "i16" | "i32" | "i64"
    | "u8" | "u16" | "u32" | "u64"

;----------------------------------------------------------------------------
;
; A "use" directive brings an enum's values into the current scope's lookup
; chain so they may be referenced without the EnumName: qualifier. Lookup
; order is local declarations, then names brought in by use, then enclosing
; scopes. Two use directives in the same scope that import a colliding value
; name make that specific name ambiguous; references must then qualify.

use-directive
    ::= "use" IDENTIFIER ";"

;============================================================================
; VARIABLE DECLARATIONS
;----------------------------------------------------------------------------
;
; A ":" after a variable name followed by an arena or heap name places that
; variable in that vault.
;
; The ugly mask (refinement ceiling) immediately follows the variable name
; with no intervening whitespace, using "~" and 1–8 positional letters.
; Unspecified trailing positions default to the zero (less-refined) side.
; Use "_" as a placeholder to skip a position and accept its default.
;
; "arc" before a type declares a shared-pointer variable (arc ownership):
;   arc Node next;           -- shared pointer to Node
;   arc var handler;         -- shared pointer to a morphing variant
;
; "ref" declares a variable whose type is inferred from its first assignment
; and then frozen — no further morphing. This is the standard form for
; function reference variables:
;   ref fn1 = myInstance.AddToList(zs8);
;   ref fn2 = MyClass:Swap(i32, i32);
;   ref x   = 42;            -- x is u8, will not morph to a larger type
;
; "var" declares a variable that infers its type and may continue to morph.

variable-declaration
    ::= [ "once" ] { low-refinement-qualifier } ( "var" | "ref" | type-specifier ) <IDENTIFIER> { array-suffix } [ <UGLY-MASK> ] [ ":" vault-specifier ]
    [ ( "=" expression | ":=" lvalue-expression ) ] ";"

; The bracket-suffix form (i32 a[5]) attaches the array size to the variable,
; not the type — so "i32 a[5], b;" declares a five-element array a and a
; single i32 b, not two arrays. See section 9.
; Multiple suffixes stack for multi-dimensional arrays: i32 m[3][4].
; The size expression may be omitted when an initializer determines it
; (i32 a[] = { 1, 2, 3 };), and may be a runtime expression — it is fixed
; at declaration time, not required to be a compile-time constant.
;
; "once" is permitted on any local variable declaration (section 26a). The
; storage initializes lazily on first reach, persists for program lifetime,
; and is shared across every invocation of the enclosing function. The
; combination "immutable once" is permitted for "compute once on first
; access, then never change" (section 26f).

array-suffix
    ::= "[" [ expression ] "]"

vault-specifier
    ::= IDENTIFIER

lvalue-expression
    ::= lvalue-root { lvalue-postfix }

lvalue-root
    ::= IDENTIFIER
    | function-call
    | <"$"> <unary-expr>    ; dereferenced pointer is an addressable location
    | "(" expression ")"

lvalue-postfix
    ::= "." IDENTIFIER
    | <"->"> <IDENTIFIER>
    | "[" expression "]"

lvalue
    ::= lvalue-expression    ; semantic checker additionally verifies the result is mutable

;=============================================================================
; END OF BNF SEQUENCE
;=============================================================================
